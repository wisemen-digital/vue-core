{
  "name": "@wisemen/time",
  "version": "0.0.30",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "imports": {
    "#src/*": "./dist/*"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
